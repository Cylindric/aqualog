# NETWORK SETTINGS
PROXY_PORT_HTTP={{ aqualog_proxy_exposed_port }}
PROXY_PORT_HTTPS=443
AUTH_PORT_HTTP={{ aqualog_auth_exposed_port }}
BACKEND_PORT_HTTP={{ aqualog_backend_exposed_port }}
FRONTEND_PORT_HTTP={{ aqualog_frontend_exposed_port }}
AUTH_PORT_HTTPS={{ aqualog_auth_exposed_port_https }}

# CONTAINER VERSIONS
AUTHENTIK_TAG=2026.5.5
POSTGRES_TAG=16-alpine
CADDY_TAG=alpine
FRONTEND_TAG=latest
BACKEND_TAG=latest

# AUTH SERVER SETTINGS
AUTHENTIK_LISTEN__TRUSTED_PROXY_CIDRS=172.18.0.1/16
AUTHENTIK_ERROR_REPORTING__ENABLED=false
AUTHENTIK_POSTGRESQL__HOST=authdb
AUTHENTIK_POSTGRESQL__NAME=authentik

AUTHENTIK_POSTGRESQL__PASSWORD={{ aqualog_authentik_password }}
AUTHENTIK_POSTGRESQL__USER=authentik
AUTHENTIK_SECRET_KEY={{ aqualog_authentik_secret_key }}

# COMMON SETTINGS
AQUALOG_OAUTH_ISSUER_URL=https://auth.aqualog.cylindric.net/application/o/aqualog/
AQUALOG_OAUTH_CLIENT_ID={{ aqualog_oauth_client_id }}

# BACKEND SETTINGS
AQUALOG_APP_ENV=dev
AQUALOG_API_VERSION=v1
AQUALOG_LOG_LEVEL=INFO
AQUALOG_DB_HOST=backenddb
AQUALOG_DB_NAME=aqualog
AQUALOG_DB_USER=aqualog
AQUALOG_DB_PORT=5432

# echo "AQUALOG_DB_PASSWORD=$(openssl rand -base64 36)"
AQUALOG_DB_PASSWORD={{ aqualog_db_password }}
AQUALOG_DATABASE_URL="postgresql://${AQUALOG_DB_USER}:${AQUALOG_DB_PASSWORD}@${AQUALOG_DB_HOST}:${AQUALOG_DB_PORT}/${AQUALOG_DB_NAME}"

REQUESTS_CA_BUNDLE='/etc/ssl/certs/ca-certificates.crt'
SSL_CERT_FILE='/etc/ssl/certs/ca-certificates.crt'
CURL_CA_BUNDLE='/etc/ssl/certs/ca-certificates.crt'

# FRONTEND SETTINGS
AQUALOG_API_BASE_URL='https://api.aqualog.cylindric.net'
AQUALOG_OIDC_REDIRECT_URI='https://www.aqualog.cylindric.net/auth/callback'
AQUALOG_OIDC_POST_LOGOUT_REDIRECT_URI='https://www.aqualog.cylindric.net'
AQUALOG_OIDC_SCOPE='openid profile email offline_access'

# PROXY SETTINGS
CLOUDFLARE_API_TOKEN={{ aqualog_cf_api_token }}

# TOOLS VARIABLES
AQUALOG_OAUTH_TOKEN_ENDPOINT=https://auth.aqualog.cylindric.net/application/o/token/
